###############################################
# DELETE BOOK
###############################################

### POST book - create a throwaway book to delete
POST {{host}}/api/books
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "{{$random.book.title}}",
  "author": "{{$random.name.fullName}}",
  "isbn": "{{$random.code.isbn10}}",
  "pages": {{$random.integer(5, 2500)}},
  "rating": {{$random.integer(1, 5)}}
}

> {%
    client.global.set("deletableBookId", response.body.id);
%}

### GET check if deleted
GET  {{host}}/api/books/{{deletableBookId}}
Content-Type: application/json

### DELETE book - belongs to another user (expect 403)
DELETE {{host}}/api/books/{{deletableBookId}}
Authorization: Bearer {{token2}}

### DELETE book - without token
DELETE {{host}}/api/books/{{deletableBookId}}

### DELETE book - invalid token
DELETE {{host}}/api/books/{{deletableBookId}}
Authorization: Bearer invalid_token

### DELETE book - nonexistent ID
DELETE {{host}}/api/books/999999
Authorization: Bearer {{token}}

### DELETE book - valid (own book)
DELETE {{host}}/api/books/{{deletableBookId}}
Authorization: Bearer {{token}}

### DELETE book - same book again (expect 404, already deleted)
DELETE {{host}}/api/books/{{deletableBookId}}
Authorization: Bearer {{token}}
