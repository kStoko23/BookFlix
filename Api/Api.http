###############################################
# PUT BOOK (PutBook)
###############################################

### PUT book - valid update on own book
PUT {{host}}/api/books/{{createdBookId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "{{$random.book.title}}",
  "author": "{{$random.name.fullName}}",
  "isbn": "{{$random.code.isbn10}}",
  "pages": {{$random.integer(5, 2500)}},
  "rating": {{$random.integer(1, 5)}}
}
### GET updated book 
GET {{host}}/api/books/{{createdBookId}}
Content-Type: application/json

### PUT book - nonexistent ID
PUT {{host}}/api/books/999999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "{{$random.book.title}}",
