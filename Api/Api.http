@host = http://localhost:8080

###############################################
# AUTH - REGISTER
###############################################

### REGISTER - valid request
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - email empty
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - email missing @
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "notanemail.com",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - email missing domain
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "test@",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - email already taken (run twice with same body)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "duplicate@test.com",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - email already taken (second call, expect 409)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "duplicate@test.com",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - username empty
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234",
  "username": ""
}

### REGISTER - username too short (2 chars)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(2)}}"
}

### REGISTER - username too long (101 chars)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234",
  "username": "{{$random.alphabetic(101)}}"
}

### REGISTER - username with special characters
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234",
  "username": "admin!@#$"
}

### REGISTER - username with spaces
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234",
  "username": "admin user"
}

### REGISTER - password empty
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - password too short (< 8 chars)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Ab1",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - password too long (> 64 chars)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Aa1{{$random.alphabetic(65)}}",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - password without uppercase letter
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "admin1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - password without lowercase letter
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "ADMIN1234",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - password without digit
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "AdminAdmin",
  "username": "{{$random.alphabetic(8)}}"
}

### REGISTER - multiple errors at once
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "bad-email",
  "password": "weak",
  "username": "a"
}


###############################################
# AUTH - LOGIN
###############################################

### REGISTER - account used for login tests below
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "admin@admin.com",
  "password": "Admin1234",
  "username": "admin"
}

### LOGIN - valid credentials
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@admin.com",
  "password": "Admin1234"
}

> {%
    client.global.set("token", response.body.token);
%}

### LOGIN - nonexistent email
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "Admin1234"
}

### LOGIN - wrong password
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@admin.com",
  "password": "WrongPassword1"
}

### LOGIN - empty email
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "",
  "password": "Admin1234"
}

### LOGIN - empty password
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@admin.com",
  "password": ""
}


###############################################
# AUTH - SECOND ACCOUNT (for ownership / 403 tests)
###############################################

### REGISTER - second account
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "second@second.com",
  "password": "Second1234",
  "username": "seconduser"
}

### LOGIN - second account
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "second@second.com",
  "password": "Second1234"
}

> {%
    client.global.set("token2", response.body.token);
%}


###############################################
# GET BOOKS - list / search / pagination
###############################################

### GET all books - default pagination
GET {{host}}/api/books
Accept: application/json

### GET all books - page 0 (should clamp to 1)
GET {{host}}/api/books?page=0
Accept: application/json

### GET all books - negative page (should clamp to 1)
GET {{host}}/api/books?page=-5
Accept: application/json

### GET all books - very high page (expect empty items)
GET {{host}}/api/books?page=99999
Accept: application/json

### GET all books - pageSize 0 (should clamp to 1)
GET {{host}}/api/books?pageSize=0
Accept: application/json

### GET all books - pageSize above max (should clamp to 100)
GET {{host}}/api/books?pageSize=500
Accept: application/json

### GET all books - search with no matches
GET {{host}}/api/books?search={{$random.alphabetic(20)}}
Accept: application/json

### GET all books - search with SQL injection attempt
GET {{host}}/api/books?search='; DROP TABLE Books;--
Accept: application/json

### GET all books - filter by valid category
GET {{host}}/api/books?category=Fantasy
Accept: application/json

### GET all books - filter by invalid category value
GET {{host}}/api/books?category=NotARealCategory
Accept: application/json


###############################################
# GET BOOK BY ID
###############################################

### GET book by ID - nonexistent ID
GET {{host}}/api/books/999999
Accept: application/json

### GET book by ID - negative ID
GET {{host}}/api/books/-1
Accept: application/json

### GET book by ID - non-numeric ID (expect 404 from routing)
GET {{host}}/api/books/abc
Accept: application/json


###############################################
# GET BOOKS CATEGORIZED
###############################################

### GET books categorized - default
GET {{host}}/api/books/categorized
Accept: application/json

### GET books categorized - custom pageSize
GET {{host}}/api/books/categorized?pageSize=5
Accept: application/json


###############################################
# GET MY BOOKS
###############################################

### GET my books - without token (expect 401)
GET {{host}}/api/books/mine
Accept: application/json

### GET my books - with valid token (likely empty for fresh account)
GET {{host}}/api/books/mine
Accept: application/json
Authorization: Bearer {{token}}

### GET my books - with invalid token
GET {{host}}/api/books/mine
Accept: application/json
Authorization: Bearer invalid_token


###############################################
# POST BOOK (CreateBook)
###############################################

### POST book - valid, full payload
POST {{host}}/api/books
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "{{$random.book.title}}",
  "author": "{{$random.name.fullName}}",
  "description": "{{$random.alphabetic(50)}}",
  "category": {{$random.integer(0,12)}},
  "isbn": "{{$random.code.isbn10}}",
  "pages": {{$random.integer(5, 2500)}},
  "rating": {{$random.integer(1, 5)}}
}

> {%
    client.global.set("createdBookId", response.body.id);
%}

